.docker-data/

# Evaluation result dumps — regenerated by every eval run; keep the
# directory (.gitkeep) but not the timestamped outputs.
eval/results/*.json

# Sub-proyek J frontend-demo
frontend-demo/node_modules/
frontend-demo/dist/
frontend-demo/coverage/
frontend-demo/.env.local
frontend-demo/.env.*.local

# Git worktrees + harness state (.claude/ holds local worktrees created via
# EnterWorktree; .claire/ + .clone/ are pre-existing pollution from typos —
# excluded so future `git add -A` doesn't pick them up).
.claude/
.claire/
.clone/
