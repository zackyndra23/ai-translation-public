# Copy this file to .env and fill in real values.
# Loaded by docker-compose (POSTGRES_*) and by src/config/settings.py.

# === Database (PostgreSQL container) ===
POSTGRES_USER=aitrans
POSTGRES_PASSWORD=devpassword_ganti_apa_aja
POSTGRES_DB=aitrans_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://aitrans:devpassword_ganti_apa_aja@localhost:5432/aitrans_db

# === Redis (cache + queue) ===
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# === Anthropic API ===
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-sonnet-4-6

# === App settings ===
ENVIRONMENT=development
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000

# === Cache settings ===
CACHE_TTL_SECONDS=86400
